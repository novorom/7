# Set this environment variable to secure your admin panel
# Default is "admin123" if not provided
NEXT_PUBLIC_ADMIN_PASSCODE=admin123

# Яндекс.Вебмастер — получить на webmaster.yandex.ru → Добавить сайт → HTML-метатег
NEXT_PUBLIC_YANDEX_VERIFICATION=

# Google Search Console — получить на search.google.com/search-console → HTML-тег
NEXT_PUBLIC_GOOGLE_VERIFICATION=
